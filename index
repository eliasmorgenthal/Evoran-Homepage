<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>E to O™</title>

  <link rel="stylesheet" href="css/styles.css">
</head>
<body>

<canvas id="particles"></canvas>

<div class="navbar">
  <div class="logo">E to O™</div>
  <div class="nav-links">
    <button onclick="go('home')" class="active">Home</button>
    <button onclick="go('about')">About</button>
    <button onclick="go('support')">Support</button>
    <button onclick="go('contact')">Contact</button>
  </div>
  <button class="settings-btn" onclick="toggleSettings()">Settings</button>
</div>

<div class="settings" id="settings">
  <h3>Settings</h3>
  <div class="row">
    <span>Dark Mode 🌙</span>
    <div class="switch" id="darkSwitch" onclick="toggleDark()"></div>
  </div>
</div>

<!-- Pages -->
<div id="home" class="page active">
  <div class="card">
    <div class="hero-title">E to O™</div>
    <p>E to O™ Homepage</p>
    <div class="buttons">
      <button onclick="go('about')">About</button>
      <button onclick="go('support')">Support</button>
      <button onclick="go('contact')">Contact</button>
    </div>
  </div>
</div>

<div id="about" class="page">
  <div class="card">
    <h2>About</h2>
    <p>E to O™ is a Service provider and game studio.</p>
  </div>
</div>

<div id="support" class="page">
  <div class="card">
    <h2>Support</h2>
    <p><a href="https://www.roblox.com" target="_blank">Roblox</a></p>
    <p><a href="https://discord.gg" target="_blank">Discord</a></p>
  </div>
</div>

<div id="contact" class="page">
  <div class="card">
    <h2>Contact</h2>
    <a href="mailto:etoobusinessmail@gmail.com">etoobusinessmail@gmail.com</a>
  </div>
</div>

<script src="js/app.js"></script>
<script src="js/particles.js"></script>
</body>
</html>